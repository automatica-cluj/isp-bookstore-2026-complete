# ---------------------------------------------------------------------------
# Environment configuration for compose.prod.yml
# Copy this file to `.env` and adjust values for your deployment.
# Do NOT commit the real `.env` (it is in .gitignore).
# ---------------------------------------------------------------------------

# Public hostname Caddy will terminate TLS for.
# - "localhost"                      → self-signed cert (browser warning)
# - "my-bookstore.duckdns.org"       → real Let's Encrypt cert
SITE_ADDRESS=localhost

# Image to pull from GHCR. Pin to a specific version in production.
APP_IMAGE=ghcr.io/automatica-cluj/isp-2026-bookstore:latest

# `always`  → always re-pull (recommended in prod so `:latest` / moving tags work)
# `missing` → only pull if image is absent locally
# `never`   → use the local image (useful for testing a locally-built tag)
PULL_POLICY=always

# PostgreSQL credentials. Override for any non-local deployment.
POSTGRES_DB=bookstore
POSTGRES_USER=bookstore
POSTGRES_PASSWORD=bookstore
