        </mxCell>

        <!-- Deploy commands -->
        <mxCell id="deploy_box" value="&lt;b&gt;Deploy Commands&lt;/b&gt;&lt;br&gt;&lt;hr&gt;&lt;font face=&quot;monospace&quot; size=&quot;1&quot;&gt;# Local (default: localhost, self-signed)&lt;br&gt;docker compose up -d&lt;br&gt;&lt;br&gt;# Remote (Let's Encrypt, real cert)&lt;br&gt;SITE_ADDRESS=my-app.duckdns.org \&lt;br&gt;  docker compose up -d&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingRight=10;verticalAlign=top;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="700" y="885" width="320" height="130" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
