<mxfile host="app.diagrams.net" agent="Claude" version="24.0.0" type="device">
  <diagram id="release-pipeline" name="Release &amp; Development Pipeline">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Release &amp;amp; Development Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="36" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="What happens when code moves through topic → develop → main. Driven by Conventional Commit PR titles + semantic-release." style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="56" width="1200" height="22" as="geometry" />
        </mxCell>

        <mxCell id="laneA" value="1. Code lands on develop" style="swimlane;html=1;fontSize=13;fontStyle=1;startSize=28;fillColor=#f5f5f5;strokeColor=#999999;swimlaneFillColor=#ffffff" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="1220" height="220" as="geometry" />
        </mxCell>

        <mxCell id="dev" value="Developer&#xa;(GitHub UI)" style="shape=actor;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="laneA">
          <mxGeometry x="30" y="70" width="40" height="60" as="geometry" />
        </mxCell>

        <mxCell id="topic" value="Topic branch&#xa;&lt;b&gt;feat/books-count&lt;/b&gt;&#xa;(cut from develop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="laneA">
          <mxGeometry x="110" y="70" width="160" height="60" as="geometry" />
        </mxCell>

        <mxCell id="pr1" value="Pull Request → develop&#xa;&lt;b&gt;Title: feat: add ...&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="laneA">
          <mxGeometry x="310" y="70" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="checks" value="Required checks (per-PR)" style="swimlane;html=1;fontSize=11;startSize=22;fillColor=#fff5e6;strokeColor=#d79b00" vertex="1" parent="laneA">
          <mxGeometry x="530" y="40" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ci1" value="ci.yml&#xa;&quot;Build and Test&quot;&#xa;(mvn test, JAR package)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10" vertex="1" parent="checks">
          <mxGeometry x="10" y="30" width="130" height="80" as="geometry" />
        </mxCell>
        <mxCell id="pt" value="pr-title.yml&#xa;&quot;Validate&#xa;Conventional Commits&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10" vertex="1" parent="checks">
          <mxGeometry x="145" y="30" width="125" height="80" as="geometry" />
        </mxCell>

        <mxCell id="squash" value="Squash-merge&#xa;PR title → single commit&#xa;on develop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="laneA">
          <mxGeometry x="850" y="70" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="develop" value="develop" style="shape=tape;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1" vertex="1" parent="laneA">
          <mxGeometry x="1060" y="70" width="130" height="60" as="geometry" />
        </mxCell>

        <mxCell id="eA1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneA" source="dev" target="topic">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eA2" value="open PR" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;fontSize=10" edge="1" parent="laneA" source="topic" target="pr1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eA3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneA" source="pr1" target="checks">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eA4" value="both green" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;fontSize=10" edge="1" parent="laneA" source="checks" target="squash">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eA5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneA" source="squash" target="develop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="laneB" value="2. On push: build-push.yml (runs on develop AND main — same steps, different outputs)" style="swimlane;html=1;fontSize=13;fontStyle=1;startSize=28;fillColor=#f5f5f5;strokeColor=#999999;swimlaneFillColor=#ffffff" vertex="1" parent="1">
          <mxGeometry x="40" y="340" width="1220" height="240" as="geometry" />
        </mxCell>

        <mxCell id="s1" value="1. Dry-run&#xa;semantic-release&#xa;(compute next version)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="laneB">
          <mxGeometry x="40" y="60" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="2. Docker build&#xa;build args: VERSION,&#xa;VCS_REF, BUILD_DATE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="laneB">
          <mxGeometry x="250" y="60" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="3. Push to GHCR&#xa;(branch-specific tags,&#xa;see outputs below)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10" vertex="1" parent="laneB">
          <mxGeometry x="460" y="60" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="4. semantic-release (real)&#xa;• write CHANGELOG.md&#xa;• bump pom.xml &lt;version&gt;&#xa;• git tag + GitHub Release&#xa;• commit &lt;i&gt;chore(release): X.Y.Z [skip ci]&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=6" vertex="1" parent="laneB">
          <mxGeometry x="670" y="50" width="260" height="100" as="geometry" />
        </mxCell>
        <mxCell id="skipCI" value="&quot;[skip ci]&quot; prevents&#xa;the release commit from&#xa;re-triggering the workflow" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;dashed=1" vertex="1" parent="laneB">
          <mxGeometry x="960" y="70" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="eB1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneB" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eB2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneB" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eB3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1" edge="1" parent="laneB" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eB4" style="edgeStyle=none;rounded=0;html=1;endArrow=none;endFill=0;dashed=1;strokeColor=#b85450" edge="1" parent="laneB" source="s4" target="skipCI">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="pushTrigger" value="trigger: push to develop or main" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontStyle=2" vertex="1" parent="laneB">
          <mxGeometry x="40" y="165" width="260" height="20" as="geometry" />
        </mxCell>

        <mxCell id="laneC" value="3. What gets produced" style="swimlane;html=1;fontSize=13;fontStyle=1;startSize=28;fillColor=#f5f5f5;strokeColor=#999999;swimlaneFillColor=#ffffff" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1220" height="240" as="geometry" />
        </mxCell>

        <mxCell id="betaBox" value="&lt;b&gt;develop → beta channel&lt;/b&gt;&#xa;(prerelease)" style="swimlane;html=1;fontSize=12;startSize=40;fillColor=#e8f5e9;strokeColor=#82b366;fontStyle=1" vertex="1" parent="laneC">
          <mxGeometry x="30" y="40" width="570" height="170" as="geometry" />
        </mxCell>
        <mxCell id="betaTag" value="git tag&#xa;&lt;b&gt;v1.3.0-beta.1&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="betaBox">
          <mxGeometry x="20" y="55" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="betaGhcr" value="GHCR tags&#xa;v1.3.0-beta.1&#xa;develop&#xa;sha-&lt;short&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="betaBox">
          <mxGeometry x="170" y="45" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="betaRelease" value="GitHub Release&#xa;marked &lt;b&gt;Pre-release&lt;/b&gt;&#xa;+ CHANGELOG entry" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="betaBox">
          <mxGeometry x="350" y="45" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="stableBox" value="&lt;b&gt;main → stable channel&lt;/b&gt;" style="swimlane;html=1;fontSize=12;startSize=40;fillColor=#e8f5e9;strokeColor=#82b366;fontStyle=1" vertex="1" parent="laneC">
          <mxGeometry x="620" y="40" width="570" height="170" as="geometry" />
        </mxCell>
        <mxCell id="stableTag" value="git tag&#xa;&lt;b&gt;v1.3.0&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="stableBox">
          <mxGeometry x="20" y="55" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="stableGhcr" value="GHCR tags&#xa;v1.3.0&#xa;&lt;b&gt;latest&lt;/b&gt;&#xa;main&#xa;sha-&lt;short&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="stableBox">
          <mxGeometry x="170" y="40" width="160" height="90" as="geometry" />
        </mxCell>
        <mxCell id="stableRelease" value="GitHub Release (stable)&#xa;CHANGELOG.md updated&#xa;pom.xml &lt;version&gt; bumped" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10" vertex="1" parent="stableBox">
          <mxGeometry x="350" y="45" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="promote" value="develop → main&#xa;(PR, merge commit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="laneC">
          <mxGeometry x="515" y="215" width="170" height="20" as="geometry" />
        </mxCell>

        <mxCell id="ePromote" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=classic;endFill=1;strokeColor=#d6b656" edge="1" parent="laneC" source="betaBox" target="stableBox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rulesBox" value="Commit convention → version bump" style="swimlane;html=1;fontSize=13;fontStyle=1;startSize=28;fillColor=#f5f5f5;strokeColor=#999999" vertex="1" parent="1">
          <mxGeometry x="1280" y="100" width="300" height="480" as="geometry" />
        </mxCell>
        <mxCell id="rFeat" value="feat: ...&#xa;→ &lt;b&gt;minor&lt;/b&gt;   (1.2.0 → 1.3.0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="40" width="270" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rFix" value="fix: / perf: / refactor: / revert:&#xa;→ &lt;b&gt;patch&lt;/b&gt;   (1.2.0 → 1.2.1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="100" width="270" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rMajor" value="feat!: ... &lt;i&gt;or&lt;/i&gt; body contains&#xa;BREAKING CHANGE:&#xa;→ &lt;b&gt;major&lt;/b&gt;   (1.2.0 → 2.0.0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="160" width="270" height="70" as="geometry" />
        </mxCell>
        <mxCell id="rNone" value="docs: / chore: / test: /&#xa;ci: / build: / style:&#xa;→ &lt;b&gt;no release&lt;/b&gt;&#xa;(image still pushed with sha-&lt;short&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;align=left;spacingLeft=8" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="240" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="rNoRel" value="scope &lt;b&gt;(no-release)&lt;/b&gt;&#xa;suppresses release even for feat/fix&#xa;&lt;i&gt;e.g. feat(no-release): draft ...&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="340" width="270" height="75" as="geometry" />
        </mxCell>
        <mxCell id="rNote" value="Branches:&#xa;• main  → stable  vX.Y.Z&#xa;• develop → beta  vX.Y.Z-beta.N" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#999999;fontSize=10;align=left;spacingLeft=8;dashed=1" vertex="1" parent="rulesBox">
          <mxGeometry x="15" y="425" width="270" height="45" as="geometry" />
        </mxCell>

        <mxCell id="notesTitle" value="Notes &amp;amp; gotchas" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="860" width="400" height="24" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="• PRs on develop are &lt;b&gt;squash-merged&lt;/b&gt; — the PR title is the only commit message semantic-release sees. Get it right." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="890" width="1540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="• develop → main promotion uses a &lt;b&gt;merge commit&lt;/b&gt; so each feat/fix lands on main as its own commit — semantic-release aggregates them into the stable changelog." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="912" width="1540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="• ci.yml runs on every branch and every PR. build-push.yml only runs on push to develop or main — that is where images and releases get produced." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="934" width="1540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="note4" value="• Never hand-edit CHANGELOG.md or the pom.xml &lt;version&gt; — semantic-release owns both and will overwrite you on the next release commit." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="956" width="1540" height="20" as="geometry" />
        </mxCell>
        <mxCell id="note5" value="• The release commit chore(release): X.Y.Z [skip ci] pushed back by semantic-release lives on the branch but does NOT re-fire build-push.yml — that is what [skip ci] is for." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="978" width="1540" height="20" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
